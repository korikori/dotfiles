# conky configuration
#
# The list of variables has been removed from this file in favour
# of keeping the documentation more maintainable.
# Check http://conky.sf.net for an up-to-date-list.
#
# For ideas about how to modify conky, please see:
# http://crunchbanglinux.org/forums/topic/59/my-conky-config/
#
# For help with conky, please see:
# http://crunchbanglinux.org/forums/topic/2047/conky-help/
#
# Enjoy! :)
##############################################
#  Settings
##############################################
background yes
use_xft yes
#xftfont :size=8
text_buffer_size 1366
minimum_size 1919 2
maximum_width 1920
xftalpha 0.5
out_to_console no
out_to_stderr no
extra_newline no
update_interval 1.0
total_run_times 0
own_window_type desktop
own_window yes
own_window_colour 282828
own_window_hints undecorated,above,sticky,skip_taskbar,skip_pager
double_buffer yes
draw_shades no
draw_outline no
draw_borders no
draw_graph_borders yes
uppercase no
default_color ffffff
alignment top_left
border_margin 1
gap_x 0
gap_y 4
no_buffers yes
cpu_avg_samples 2
use_spacer none
override_utf8_locale no
color3 grey
color1 6688bb
color2 ACCD8A
font hack:size=9
##############################################
#  Output
##############################################
TEXT
$alignc $font $color2 MEMORIES - $color1$mem$color2/$color1$memmax $color3 | $color2 SPACES - $color1${fs_used /}$color2/$color1${fs_size /} $color3 | $color2 CPU - $color1${cpu cpu0}% $color3 | $color2 BAT - $color1$battery_percent% | $color2 UTIME - $color1$uptime $color3 | $color2 TEMP - $color1${hwmon 0 temp 1} c $color3 
